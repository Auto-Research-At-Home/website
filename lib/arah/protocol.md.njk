{% endif %}

{% set _desc = protocol.description | default(protocol.statement_of_purpose) | default(protocol.statementOfPurpose) | default(protocol.summary) | default(protocol.purpose) %}
{% if _desc %}

{{ _desc }}

{% endif %}

