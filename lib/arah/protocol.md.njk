{% for key, value in protocol | dictsort %}
{% if key not in excluded %}

{% if value is mapping %}

### {{ key | human_key }}

{{ value | nested_md }}

{% elif value is array %}

### {{ key | human_key }}

{{ value | nested_md }}

{% else %}

**{{ key | human_key }}:** {{ value | format_leaf }}

{% endif %}

{% endif %}
{% endfor %}
