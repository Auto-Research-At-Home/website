{# Protocol JSON → Markdown (Nunjucks ≈ Jinja2). Edit this file to match a Python Jinja2 template. #}
{% set _title = protocol.title | default(protocol.name) | default(protocol.project_name) | default(protocol.projectName) %}
{% if _title %}
# {{ _title }}
{% else %}
